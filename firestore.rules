rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // SECTION 1: GLOBAL safety net (DEFAULT DENY)
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // SECTION 2: REUSABLE HARDENED GLOBAL HELPERS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // By default, require verified email for authenticated writes unless anonymous is explicitly configured
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'anonymous');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if user has admin/company privileges.
    function isCompanyAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company';
    }

    // ==========================================
    // SECTION 3: ENTITY VALIDATION BLUEPRINTS
    // ==========================================

    // User Schema validation helper
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.avatar is string && data.avatar.size() <= 10 &&
             data.role is string && (data.role == 'customer' || data.role == 'owner' || data.role == 'company') &&
             data.createdAt is string;
    }

    // Property Schema validation helper
    function isValidProperty(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 5000 &&
             data.type is string && (data.type == 'House' || data.type == 'Apartment' || data.type == 'Room' || data.type == 'Office') &&
             data.price is int && data.price >= 0 &&
             data.beds is int && data.beds >= 0 &&
             data.baths is int && data.baths >= 0 &&
             data.sqft is int && data.sqft >= 0 &&
             data.locationName is string && data.locationName.size() <= 256 &&
             data.isApproved is bool &&
             data.host is map &&
             data.createdAt is string;
    }

    // Chat Schema validation helper
    function isValidChat(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.propertyId is string && data.propertyId.size() <= 128 &&
             data.propertyTitle is string && data.propertyTitle.size() <= 256 &&
             data.tenantId is string && data.tenantId.size() <= 128 &&
             data.tenantName is string && data.tenantName.size() <= 128 &&
             data.landlordId is string && data.landlordId.size() <= 128 &&
             data.landlordName is string && data.landlordName.size() <= 128 &&
             data.lastMessageText is string && data.lastMessageText.size() <= 2000 &&
             data.lastMessageTimestamp is string;
    }

    // Message Schema validation helper
    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.senderId is string && data.senderId.size() <= 128 &&
             data.senderRole is string && (data.senderRole == 'customer' || data.senderRole == 'owner' || data.senderRole == 'company') &&
             data.text is string && data.text.size() <= 2000 &&
             data.timestamp is string;
    }

    // ==========================================
    // SECTION 4: RESOURCE RULES MATCHER
    // ==========================================

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    // Prevent setting company role directly on self-creation
                    incoming().role != 'company';
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) &&
                    // Enforce immutability of original identity fields and role
                    incoming().role == existing().role &&
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'email']);
      allow delete: if isCompanyAdmin();
    }

    // --- Properties Collection ---
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidId(propertyId) && isValidProperty(incoming()) && (
        isCompanyAdmin() || 
        (incoming().host.uid == request.auth.uid && incoming().isApproved == false)
      );
      allow update: if isEmailVerified() && isValidProperty(incoming()) && (
        isCompanyAdmin() || (
          // Landlord owner updates
          existing().host.uid == request.auth.uid &&
          incoming().host.uid == existing().host.uid &&
          // Enforce approval status cannot be tempered by Landlord
          incoming().isApproved == existing().isApproved &&
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'beds', 'baths', 'sqft', 'amenities', 'locationName'])
        )
      );
      allow delete: if isCompanyAdmin() || (isSignedIn() && existing().host.uid == request.auth.uid);
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      // Only the tenant or landlord involved in the thread can read/write
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid ||
        isCompanyAdmin()
      );
      
      // Creating a new chat requires matching identity
      allow create: if isEmailVerified() && isValidId(chatId) && isValidChat(incoming()) && (
        incoming().tenantId == request.auth.uid
      );
      
      // Updates are restricted to participants
      allow update: if isEmailVerified() && isValidChat(incoming()) && (
        existing().tenantId == request.auth.uid || 
        existing().landlordId == request.auth.uid
      ) && incoming().tenantId == existing().tenantId &&
          incoming().landlordId == existing().landlordId &&
          incoming().propertyId == existing().propertyId &&
          incoming().diff(existing()).affectedKeys().hasOnly(['lastMessageText', 'lastMessageTimestamp']);

      allow delete: if isCompanyAdmin();

      // --- Nested Message Subcollection ---
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid ||
          isCompanyAdmin()
        );
        allow create: if isEmailVerified() && isValidId(messageId) && isValidMessage(incoming()) && (
          incoming().senderId == request.auth.uid
        ) && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid
        );
        allow update, delete: if isCompanyAdmin();
      }
    }
  }
}
